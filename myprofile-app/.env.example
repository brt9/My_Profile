APP_NAME="Pedro Felipe — Desenvolvedor Full Stack"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=myprofile
DB_USERNAME=myprofile
DB_PASSWORD=myprofile_local
DB_TIMEZONE=UTC

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Conteúdo público do portfólio. Links vazios são ocultados na interface.
PORTFOLIO_NAME="Pedro Felipe"
PORTFOLIO_ROLE="Desenvolvedor Full Stack"
PORTFOLIO_LOCATION="Natal, RN · Brasil"
PORTFOLIO_COMPANY="CAERN — Companhia de Águas e Esgotos do RN"
PORTFOLIO_EMAIL=
PORTFOLIO_GITHUB=
PORTFOLIO_LINKEDIN=https://www.linkedin.com/in/pedrofelipebrt9
PORTFOLIO_WEATHER_ENABLED=true

# GitHub: username obrigatório para o card; token opcional aumenta o rate limit.
GITHUB_USERNAME=brt9
GITHUB_TOKEN=

# Steam: opcional. A chave é secreta e nunca deve ser commitada.
STEAM_API_KEY=
STEAM_ID=

# Telemetria: token secreto compartilhado somente entre servidor e agente.
TELEMETRY_TOKEN=
TELEMETRY_TTL=180
TELEMETRY_STALE_AFTER=30
TELEMETRY_OFFLINE_AFTER=180
TELEMETRY_RAW_RETENTION_DAYS=7
TELEMETRY_AGGREGATE_RETENTION_DAYS=90
TELEMETRY_MAX_PAYLOAD_BYTES=16384
